# ── Required ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Required for production: License signing key ─────────────────
# Generate with: openssl rand -hex 32
JANUS_LICENSE_SECRET=

# ── Optional: API authentication ──────────────────────────────────
# Set this to protect dashboard API endpoints with a Bearer token
JANUS_API_KEY=

# ── Optional: Config file path ────────────────────────────────────
# JANUS_CONFIG_PATH=./janus.toml

# ── Optional: Database path (defaults to ~/.janus/janus.db) ───────
# JANUS_DB_PATH=

# ── Optional: CORS allowed origins (comma-separated) ─────────────
# JANUS_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Optional: Dev mode (DO NOT use in production) ─────────────────
# Enables PRO features without a real license key
# JANUS_DEV_MODE=true

# ── Optional: Mock tool execution (for development/testing) ──────
# JANUS_MOCK_TOOLS=true

# ── Optional: Stripe billing ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
JANUS_BASE_URL=http://localhost:3000

# ── Optional: Resend email (license delivery) ─────────────────────
RESEND_API_KEY=

# ── Frontend (.env.local in frontend/) ────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_JANUS_API_KEY=
